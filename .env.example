# AI Provider Configuration
# ─────────────────────────────
# Supports ANY OpenAI-compatible API. Just change BASE_URL and provide the
# matching API key + model name. Examples:
#
#   OpenAI:     https://api.openai.com/v1
#   Groq:       https://api.groq.com/openai/v1
#   OpenRouter: https://openrouter.ai/api/v1
#   DeepSeek:   https://api.deepseek.com
#   Ollama:     http://localhost:11434/v1
#
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# The model to use (depends on provider):
#   OpenAI:     gpt-4o-mini | gpt-4o | gpt-4-turbo
#   Groq:       llama-3.1-8b-instant | llama-3.3-70b-versatile | mixtral-8x7b-32768
#   OpenRouter: openai/gpt-4o-mini | meta-llama/llama-3-8b-instruct
#   DeepSeek:   deepseek-chat
#   Ollama:     llama3 | mistral | codellama
OPENAI_MODEL=gpt-4o-mini

# Maximum tokens per response
MAX_TOKENS=2048

# Max context tokens to keep in conversation history (oldest messages trimmed)
MAX_CONTEXT_TOKENS=6144

# Server Configuration
PORT=3000

# Allowed CORS origin (use '*' for development, restrict in production)
CORS_ORIGIN=*

# Rate limiting: max messages per minute per session
RATE_LIMIT_PER_MINUTE=20
